{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ingeniometrix.local/schemas/research-blueprint-core.schema.json",
  "title": "ResearchBlueprintCoreDraft",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "project_title",
    "template_key",
    "degree_level",
    "university",
    "program",
    "research_line",
    "problem_statement",
    "justification",
    "general_objective",
    "specific_objectives",
    "research_questions",
    "proposed_methodology",
    "population_and_sample",
    "analysis_plan",
    "assumptions"
  ],
  "properties": {
    "project_title": { "type": "string", "minLength": 1 },
    "template_key": { "type": "string", "minLength": 1 },
    "degree_level": { "type": "string", "enum": ["MAESTRIA", "POSGRADO"] },
    "university": { "type": "string", "minLength": 1 },
    "program": { "type": "string", "minLength": 1 },
    "research_line": { "type": "string", "minLength": 1 },
    "problem_statement": { "type": "string", "minLength": 1 },
    "problem_delimitation": { "type": "string", "minLength": 1 },
    "justification": { "type": "string", "minLength": 1 },
    "general_objective": { "type": "string", "minLength": 1 },
    "specific_objectives": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "research_questions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "proposed_methodology": { "type": "string", "minLength": 1 },
    "population_and_sample": { "type": "string", "minLength": 1 },
    "analysis_plan": { "type": "string", "minLength": 1 },
    "assumptions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "references_used": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["reference_id", "title", "doi"],
        "properties": {
          "reference_id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "doi": { "type": ["string", "null"] }
        }
      }
    },
    "limitations": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
