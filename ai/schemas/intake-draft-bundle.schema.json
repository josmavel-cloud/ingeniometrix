{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ingeniometrix.local/schemas/intake-draft-bundle.schema.json",
  "title": "IntakeDraftBundle",
  "type": "object",
  "additionalProperties": false,
  "required": ["drafts"],
  "properties": {
    "drafts": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "label",
          "topic",
          "problemContext",
          "researchLine",
          "academicConstraints",
          "targetPopulation",
          "availableData",
          "preferredMethodology",
          "advisorNotes"
        ],
        "properties": {
          "label": { "type": "string", "minLength": 1 },
          "topic": { "type": "string", "minLength": 1 },
          "problemContext": { "type": "string", "minLength": 1 },
          "researchLine": { "type": "string", "minLength": 1 },
          "academicConstraints": { "type": "string", "minLength": 1 },
          "targetPopulation": { "type": "string", "minLength": 1 },
          "availableData": { "type": "string", "minLength": 1 },
          "preferredMethodology": { "type": "string", "minLength": 1 },
          "advisorNotes": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
