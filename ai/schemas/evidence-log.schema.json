{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ingeniometrix.local/schemas/evidence-log.schema.json",
  "title": "EvidenceLog",
  "type": "object",
  "additionalProperties": false,
  "required": ["project_id", "blueprint_version", "entries"],
  "properties": {
    "project_id": { "type": "string", "minLength": 1 },
    "blueprint_version": { "type": "integer", "minimum": 1 },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "provider",
          "provider_id",
          "title",
          "retrieval_timestamp",
          "selected_by_user"
        ],
        "properties": {
          "provider": { "type": "string", "minLength": 1 },
          "provider_id": { "type": "string", "minLength": 1 },
          "doi": { "type": "string" },
          "title": { "type": "string", "minLength": 1 },
          "retrieval_timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "selected_by_user": { "type": "boolean" }
        }
      }
    }
  }
}
