{
  "type": "object",
  "additionalProperties": false,
  "required": ["detections"],
  "properties": {
    "detections": {
      "type": "array",
      "maxItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["reference_id", "detected_language", "confidence"],
        "properties": {
          "reference_id": {
            "type": "string",
            "minLength": 1
          },
          "detected_language": {
            "type": "string",
            "enum": ["es", "en", "pt", "fr", "de", "it", "other"]
          },
          "confidence": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "rationale": {
            "type": ["string", "null"],
            "maxLength": 280
          }
        }
      }
    }
  }
}
