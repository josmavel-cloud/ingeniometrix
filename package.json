{
  "name": "ingeniometrix",
  "version": "0.1.0",
  "private": true,
  "description": "MVP de Ingeniometrix",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "typecheck": "next typegen && tsc --noEmit",
    "brand:generate": "powershell -ExecutionPolicy Bypass -File scripts/generate-brand-assets.ps1",
    "debug:providers": "node scripts/debug-research-providers.mjs",
    "debug:blueprint": "node scripts/debug-blueprint-package.mjs",
    "debug:blueprint:reuse": "node scripts/debug-blueprint-package.mjs --reuse-server",
    "debug:blueprint:report": "node scripts/debug-blueprint-report.mjs",
    "debug:master-blueprint": "node scripts/debug-master-blueprint-engine.mjs",
    "debug:master-blueprint:reuse": "node scripts/debug-master-blueprint-engine.mjs --reuse-server",
    "debug:workflow": "node scripts/debug-workflow-runner.mjs",
    "debug:workflow:reuse": "node scripts/debug-workflow-runner.mjs --reuse-server",
    "smoke:deployment": "node scripts/smoke-deployment.mjs",
    "smoke:deployment:workspace": "node scripts/smoke-deployment.mjs --workspace",
