    "taxonomy:seed": "node scripts/seed-taxonomy-catalogs.mjs",
    "taxonomy:backfill": "node scripts/backfill-reference-taxonomy.mjs",
    "taxonomy:backfill:projects": "node scripts/backfill-project-knowledge-fields.mjs",
    "taxonomy:backfill:keywords": "node scripts/backfill-reference-keywords.mjs",
