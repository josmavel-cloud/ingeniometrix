# App
APP_NAME=ingeniometrix
NODE_ENV=development
APP_PORT=3000
LOG_LEVEL=info

# Database
POSTGRES_DB=ingeniometrix
POSTGRES_USER=ingeniometrix
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5433
DATABASE_URL=postgresql://ingeniometrix:change-me@localhost:5433/ingeniometrix?schema=public

# LLM Provider
LLM_PROVIDER=openai
LLM_DEFAULT_MODEL=gpt-5.4
LLM_FAST_MODEL=gpt-5.4-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Research Providers
OPENALEX_API_KEY=
CROSSREF_MAILTO=

# Local Paths
IMX_ARTIFACTS_DIR=./artifacts-local

# Future Release 0.5 placeholders
PAYMENT_PROVIDER=
PAYMENT_SECRET_KEY=
PAYMENT_WEBHOOK_SECRET=
EMAIL_PROVIDER=
EMAIL_FROM=
EMAIL_API_KEY=
