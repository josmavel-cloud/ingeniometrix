# App
APP_NAME=ingeniometrix
NODE_ENV=development
APP_PORT=3000
LOG_LEVEL=info
NEXT_PUBLIC_SITE_URL=https://ingeniometrix.com
IMX_AUTHLESS_WORKSPACE=0

# Database
# Local Docker defaults use POSTGRES_PORT=5433. Vercel does not use APP_PORT or POSTGRES_PORT.
# For Vercel Marketplace Prisma Postgres, DATABASE_URL is injected by the integration.
# For Neon or another managed Postgres, paste the pooled/runtime URL in DATABASE_URL.
# If your provider exposes a direct/unpooled URL, put it in DATABASE_URL_UNPOOLED.
# If it does not, set DATABASE_URL_UNPOOLED to the same value as DATABASE_URL.
POSTGRES_DB=ingeniometrix
POSTGRES_USER=ingeniometrix
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5433
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require

# LLM Provider
LLM_PROVIDER=openai
LLM_DEFAULT_MODEL=gpt-5.4
LLM_FAST_MODEL=gpt-5.4-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Research Providers
OPENALEX_API_KEY=
CROSSREF_MAILTO=

# Backend-only user provisioning
ADMIN_USER_EMAIL=
ADMIN_USER_PASSWORD=
ADMIN_USER_NAME=
ADMIN_ASSIGN_ALL_PROJECTS=0

# Deployment smoke checks
SMOKE_USER_EMAIL=
SMOKE_USER_PASSWORD=

# Local Paths
IMX_ARTIFACTS_DIR=./artifacts-local

# Future Release 0.5 placeholders
PAYMENT_PROVIDER=
PAYMENT_SECRET_KEY=
PAYMENT_WEBHOOK_SECRET=
EMAIL_PROVIDER=
EMAIL_FROM=
EMAIL_API_KEY=
