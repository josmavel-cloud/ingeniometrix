    {
      "label": "FEMA P-749 Earthquake-Resistant Design Concepts",
      "url": "https://www.fema.gov/sites/default/files/documents/fema_p-749-earthquake-resistant-design-concepts_112022.pdf",
      "note": "Uses seismic isolation, base isolation, elastomeric bearings, and sliding or friction pendulum terminology."
    },
    {
      "label": "NIST SP 832v1 Earthquake protection in buildings through base isolation",
      "url": "https://www.nist.gov/publications/earthquake-protection-buildings-through-base-isolation",
      "note": "Provides baseline terminology for earthquake protection through base isolation."
    },
    {
      "label": "ASCE/SEI 41-23",
      "url": "https://www.asce.org/publications-and-news/codes-and-standards/asce-sei-41",
      "note": "Explicitly includes seismic isolation and energy dissipation systems in the retrofit and evaluation standard."
    }
  ],
